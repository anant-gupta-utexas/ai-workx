{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/block-no-verify.py" },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-security.py" },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/commit-quality.py" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/suggest-compact.py" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/large-file-blocker.py" },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/doc-file-warning.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/console-log-warning.py" }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/test-file-reminder.py" }
        ]
      }
    ]
  }
}
