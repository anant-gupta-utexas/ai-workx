{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "sh hooks/run-hook.sh hooks/experiment-budget-guard.js" },
          { "type": "command", "command": "sh hooks/run-hook.sh hooks/sky-auto-auth.js" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "sh hooks/run-hook.sh hooks/result-regression-check.js" }
        ]
      }
    ]
  }
}
