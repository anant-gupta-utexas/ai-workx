{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/experiment-budget-guard.py" },
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/sky-auto-auth.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          { "type": "command", "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/result-regression-check.py" }
        ]
      }
    ]
  }
}
